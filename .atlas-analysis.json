  "keyFeatures": [
    "Hardware-aware model recommendations across 200+ dynamic Ollama models",
    "4D scoring engine (Quality, Speed, Fit, Context) weighted by use case",
    "Multi-GPU hardware detection: Apple Silicon, NVIDIA CUDA, AMD ROCm, Intel Arc",
    "Full Ollama integration: pull, run, list, remove, benchmark, compare",
    "Model Context Protocol (MCP) server for Claude Code integration",
    "Enterprise policy governance with audit export (JSON, CSV, SARIF)",
    "Calibrated routing via JSONL prompt suites and YAML policy artifacts",
    "Interactive CLI panel with animated banner and command navigation",
    "Zero native dependencies — pure JavaScript on Node.js 16+"
  ],
  "publicApiSurface": [
    "llm-checker hw-detect",
    "llm-checker check [--policy <file>] [--use-case <type>] [--runtime <runtime>]",
    "llm-checker recommend [--category <cat>] [--calibrated [file]] [--policy <file>]",
    "llm-checker search <query> [--use-case <type>] [--max-size <gb>] [--quant <type>]",
    "llm-checker installed",
    "llm-checker calibrate --suite <file> --models ... [--dry-run] [--policy-out <file>]",
    "llm-checker ollama-plan",
    "llm-checker ai-check",
    "llm-checker ai-run [--calibrated] [--category <cat>] [--prompt <text>]",
    "llm-checker sync",
    "llm-checker smart-recommend [--use-case <type>]",
    "llm-checker policy init",
    "llm-checker policy validate <file>",
    "llm-checker audit export --policy <file> --command <cmd> --format <fmt>",
    "llm-checker gpu-plan",
    "llm-checker verify-context",
    "llm-checker amd-guard",
    "llm-checker toolcheck",
    "llm-checker mcp-setup",
    "llm-checker-mcp (MCP server binary)"
